<% layout("/layouts/guestboilerplate") %>
<% style = '<link rel="stylesheet" href="/css/auth/register.css">' %>

<div class="register-wrapper">

    <div class="register-card">

        <h1 class="register-title">Create Your Account</h1>

        <p class="register-subtitle">Register according to your role</p>

        <div class="register-buttons">

            <a href="/auth/register/student" class="role-btn student-btn">
                🎓 Register as Student
            </a>

            <div class="divider">OR</div>

            <a href="/auth/register/admin" class="role-btn admin-btn">
                🛠 Register as Admin
            </a>

        </div>

    </div>

</div>