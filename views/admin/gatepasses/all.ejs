<% layout("/layouts/adminboilerplate") %>
<link rel="stylesheet" href="/css/admin/gatepassCards.css">

<div class="container application-section">

    <h2 class="application-title">All Gate Pass Applications</h2>

    <div class="row g-4">

        <% if(!passes || passes.length === 0){ %>

            <div class="no-data-message">
                ⚠ No Application till date.
            </div>

        <% } %>

        <% passes.forEach(pass => { %>

        <div class="col-lg-4 col-md-6 col-12">

            <div class="application-card">

                <!-- HEADER -->

                <div class="card-header">

                    <h5><%= pass.user.userName %></h5>

                    <span class="roll">
                        Roll : <%= pass.user.rollNumber %>
                    </span>

                </div>


                <!-- BODY -->

                <div class="card-body">

                    <div class="info">
                        <span class="label">Reason For Leave</span>
                        <p><%= pass.reason %></p>
                    </div>

                    <div class="info">
                        <span class="label">Exit Date</span>
                        <p>
                            <%= pass.exitDate ? pass.exitDate.toISOString().split("T")[0] : "-" %>
                        </p>
                    </div>

                    <div class="info">
                        <span class="label">Return Date</span>
                        <p>
                            <%= pass.returnDate ? pass.returnDate.toISOString().split("T")[0] : "-" %>
                        </p>
                    </div>

                </div>


                <!-- FOOTER -->

                <div class="card-footer">

                    <% if(pass.status === "Pending"){ %>

                        <span class="status pending">Status : Pending</span>

                        <div class="action-buttons">

                            <form action="/admin/gatepasses/<%= pass._id %>/approve" method="POST">
                                <button class="btn approve-btn">Approve</button>
                            </form>

                            <form action="/admin/gatepasses/<%= pass._id %>/reject" method="POST">
                                <button class="btn reject-btn">Reject</button>
                            </form>

                        </div>

                    <% } %>


                    <% if(pass.status === "Approved"){ %>

                        <span class="status approved">Status : Approved</span>

                    <% } %>


                    <% if(pass.status === "Rejected"){ %>

                        <span class="status rejected">Status : Rejected</span>

                    <% } %>

                </div>

            </div>

        </div>

        <% }) %>

    </div>

</div>