<% layout("/layouts/adminboilerplate") %>
<% style = '<link rel="stylesheet" href="/css/admin/dashboard.css">' %>

<div class="stats">
    <div class="stat-card">
        <h3><%= pendingCount %></h3>
        <p>Pending</p>
    </div>
    <div class="stat-card">
        <h3><%= approvedCount %></h3>
        <p>Approved</p>
    </div>
    <div class="stat-card">
        <h3><%= rejectedCount %></h3>
        <p>Rejected</p>
    </div>
</div>